# AnyRouter 账号配置
# 基础配置（手动获取 session）
ANYROUTER_ACCOUNTS=[{"cookies":{"session":"你的session值"},"api_user":"你的api_user值"}]

# 自动续期配置（session 过期时自动通过 GitHub OAuth 重新登录）
# ANYROUTER_ACCOUNTS=[{"name":"主账号","cookies":{"session":""},"api_user":"88888","github_username":"your_github_username","github_password":"your_github_password","totp_secret":"YOUR_TOTP_SECRET_BASE32"}]

# Cloudflare KV 认证（用于持久化续期后的 session）
# AUTH_VALUE=your_auth_value

# 可选：通知配置
# DINGDING_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# EMAIL_USER=your_email@example.com
# EMAIL_PASS=your_password
# EMAIL_TO=recipient@example.com
# PUSHPLUS_TOKEN=your_pushplus_token
# SERVERPUSHKEY=your_server_pushkey
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# WEIXIN_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
